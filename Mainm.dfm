  object qryRollInfo: TMyQuery
    SQL.Strings = (
      'SELECT'
      '  rion.roll_id '#39#1050#1086#1076#39','
      '  rion.article '#39#1040#1088#1090#1080#1082#1091#1083#39','
      '  p.nameRus '#39#1048#1084#1103#39','
      '  rion.stickers_count '#39#1050#1086#1083'-'#1074#1086#39','
      '  op.Name '#39#1053#1072#1079#1074#1072#1085#1080#1077' '#1079#1072#1082#1072#1079#1072#39','
      '  op.createdDate '#39#1044#1072#1090#1072' '#1089#1086#1079#1076#1072#1085#1080#1103#39','
      
        '  ROUND(stickers_count / (pg.sheetsInBlock / pg.sheetsInSet)) AS' +
        ' '#39#1050#1086#1083'-'#1074#1086' '#1073#1083#1086#1082#1086#1074#39','
      '  rion.parent_id'
      'FROM Rolls_in_orders_New rion'
      '  LEFT JOIN Orders_proizvodstvo op'
      '    ON rion.order_id = op.id'
      '  LEFT JOIN Product p'
      '    ON p.article = rion.article'
      '  LEFT JOIN ProductGroup pg'
      '    ON p.groupId = pg.id'
      'WHERE (rion.roll_id = :rolls_in_orders_roll_id)'
      'OR (rion.parent_id = :parent_id'
      'AND rion.order_id = :order_id);')
    Options.FieldOrigins = foNone
    Left = 40
    Top = 72
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'rolls_in_orders_roll_id'
        Value = nil
      end
      item
        DataType = ftUnknown
        Name = 'parent_id'
        Value = nil
      end
      item
        DataType = ftUnknown
        Name = 'order_id'
        Value = nil
      end>
  end
