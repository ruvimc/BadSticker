  object qryRollBlockInfo: TMyQuery
    SQL.Strings = (
      
        'SELECT ranges.roll_id '#39#1056#1091#1083#1086#1085#39', op.name '#39#1047#1072#1082#1072#1079#39', CONCAT(ranges.st' +
        'art_block, '#39'-'#39', ranges.end_block) '#39#1044#1080#1072#1087#1072#1079#1086#1085#39' '
      'FROM ('
      '    SELECT '
      '        bir.roll_id,'
      
        '        COALESCE(bir.first_block_id, bir.last_block_id) AS start' +
        '_block,'
      
        '        LEAD(COALESCE(bir.first_block_id, bir.last_block_id)) OV' +
        'ER ('
      '            PARTITION BY roll_id '
      '            ORDER BY datecreate'
      '        ) AS end_block,'
      '        bir.first_block_id'
      '    FROM blocks_in_roll bir'
      ') AS ranges'
      
        'LEFT JOIN Rolls_in_orders_new rion ON rion.roll_id = ranges.roll' +
        '_id'
      'LEFT JOIN Orders_proizvodstvo op ON op.id = rion.order_id'
      'WHERE ranges.first_block_id IS NOT NULL '
      '  AND :blockId BETWEEN LEAST(start_block, end_block) '
      '                        AND GREATEST(start_block, end_block);')
    Options.FieldOrigins = foNone
    Left = 126
    Top = 192
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'blockId'
        Value = nil
      end>
  end
