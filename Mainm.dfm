  object qryGetStatus: TMyQuery
    SQL.Strings = (
      
        '-- SELECT rs.roll_statuses_name '#39#1057#1090#1072#1090#1091#1089#39', e.equipment_id '#39#1054#1073#1086#1088#1091#1076 +
        #1086#1074#1072#1085#1080#1077#39', p.person_fio '#39#1054#1087#1077#1088#1072#1090#1086#1088#39', rw.roll_date_time '#39#1044#1072#1090#1072#39', rw.r' +
        'oll_status, rs.finished FROM rolls_workflow rw'
      '-- LEFT JOIN person p ON p.person_id = rw.roll_person'
      
        '-- LEFT JOIN roll_statuses rs ON rs.roll_statuses_id = rw.roll_s' +
        'tatus'
      
        '-- LEFT JOIN equipment e ON e.equipment_id = rw.roll_equipment_i' +
        'd'
      '-- WHERE rw.roll_equipment_id = :eqid'
      '-- ORDER BY rw.roll_date_time DESC'
      '-- LIMIT 50;'
      ''
      '(SELECT '
      '    rs.roll_statuses_name AS '#39#1057#1090#1072#1090#1091#1089#39', '
      '    e.equipment_name AS '#39#1054#1073#1086#1088#1091#1076#1086#1074#1072#1085#1080#1077#39', '
      '    p.person_fio AS '#39#1054#1087#1077#1088#1072#1090#1086#1088#39', '
      '    rw.roll_date_time AS '#39#1044#1072#1090#1072#39', '
      '    rw.roll_status,'
      '    rs.finished '
      'FROM rolls_workflow rw'
      'LEFT JOIN person p ON p.person_id = rw.roll_person'
      
        'LEFT JOIN roll_statuses rs ON rs.roll_statuses_id = rw.roll_stat' +
        'us'
      'LEFT JOIN equipment e ON e.equipment_id = rw.roll_equipment_id'
      'WHERE rw.roll_equipment_id = :eqid)'
      ''
      'UNION ALL'
      ''
      '(SELECT '
      
        '    CASE WHEN bw.finished THEN '#39#1041#1083#1086#1082' '#1086#1082#1086#1085#1095#1077#1085#39' ELSE '#39#1041#1083#1086#1082' '#1085#1072#1095#1072#1090#39' ' +
        'END, '
      '    e.equipment_name, '
      '    p.person_fio, '
      '    bw.datecreate, '
      '    0,          -- '#1047#1072#1075#1083#1091#1096#1082#1072' '#1076#1083#1103' 5-'#1075#1086' '#1089#1090#1086#1083#1073#1094#1072' (roll_status)'
      '    bw.finished  -- 6-'#1081' '#1089#1090#1086#1083#1073#1077#1094
      'FROM blocks_workflow bw'
      'LEFT JOIN person p ON p.person_id = bw.block_person'
      'LEFT JOIN equipment e ON e.equipment_id = bw.equip_id'
      'WHERE bw.equip_id = :eqid)'
      ''
      'ORDER BY `'#1044#1072#1090#1072'` DESC'
      'LIMIT 50;'
      '')
    Options.FieldOrigins = foNone
    Left = 128
    Top = 24
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'eqid'
        Value = nil
      end
      item
        DataType = ftUnknown
        Name = 'eqid'
        Value = nil
      end>
  end
